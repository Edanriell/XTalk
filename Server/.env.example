# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=connect_db
DB_SSL=disable

# Docker Compose (used as POSTGRES_* env vars for the postgres container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=connect_db

# JWT Configuration
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change_me_to_a_strong_password
RABBITMQ_URL=amqp://guest:change_me@localhost:5672/

# Service Ports
AUTH_SERVICE_PORT=50051
USER_SERVICE_PORT=50052
CHAT_SERVICE_PORT=50053
MESSAGE_SERVICE_PORT=50054
MATCHING_SERVICE_PORT=50055
API_GATEWAY_PORT=8080
